# Active storage provider: "minio" (default) or "r2"
STORAGE_PROVIDER=minio

# ── MinIO (local Docker) ──────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=workshop-images

# ── Cloudflare R2 ─────────────────────────────────────────────
# To demo the provider switch: set STORAGE_PROVIDER=r2 and fill these in.
# Account ID: Cloudflare dashboard → R2 → "Account ID" (top right)
# Tokens:     R2 → "Manage R2 API tokens" → Create token (Object Read & Write)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET=workshop-images

PORT=3001
